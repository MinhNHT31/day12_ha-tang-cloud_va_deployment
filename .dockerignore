# Không copy những file này vào Docker image
# Lý do: giảm context size, tăng security

# Python
__pycache__/
**/__pycache__/
*.pyc
**/*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
**/.pytest_cache/

# Virtual environment
venv/
env/
.venv/
**/venv/
**/env/
**/.venv/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Secrets — QUAN TRỌNG: không bao giờ đưa .env vào image
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Git / local agent metadata
.git/
.gitignore
.codex/
.agents/

# Docs, screenshots, logs, tests
*.md
tests/
docs/
screenshots/
*.png
*.jpg
*.jpeg
*.gif
*.log
